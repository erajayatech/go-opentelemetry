# Multiple Exporters Configuration

# New Relic (optional)
ENABLE_NEW_RELIC=false
NEW_RELIC_API_KEY=your-new-relic-api-key-here
NEW_RELIC_ENDPOINT=otlp.nr-data.net:4317

# Datadog (optional)
ENABLE_DATADOG=false
DATADOG_API_KEY=your-datadog-api-key-here
DATADOG_ENDPOINT=trace-agent.datadoghq.com:4317
DATADOG_USE_HTTP=false

# Jaeger (optional)
ENABLE_JAEGER=false
JAEGER_ENDPOINT=localhost:4317

# Generic OTLP (optional)
ENABLE_OTLP=false
OTLP_ENDPOINT=localhost:4317
OTLP_USE_HTTP=false
OTLP_HEADERS=Authorization=Bearer token,X-Custom-Header=value

# Stdout (always enabled if no other exporters are configured)
ENABLE_STDOUT=false
OTEL_PRETTY_PRINT=true

# Service Configuration
SERVICE_NAME=multiple-exporters-service
SERVICE_VERSION=1.0.0
APP_ENV=production

# Example: Enable New Relic and Datadog simultaneously
# ENABLE_NEW_RELIC=true
# ENABLE_DATADOG=true
# NEW_RELIC_API_KEY=your-new-relic-api-key
# DATADOG_API_KEY=your-datadog-api-key
